# .env 模板：复制为 .env 并填写（.env 不入库，本模板入库供协作者参考）
ARK_API_KEY=
# 方舟模型 ID 带版本后缀，用 /api/v3/models 接口查询 key 可访问的完整列表
ARK_SCORE_MODEL=deepseek-v4-flash-260425
ARK_DEEPREAD_MODEL=deepseek-v4-pro-260425

# flash 牌价（元/百万 tokens）：查方舟控制台该模型定价页填入；
# 留空则 flash 用量按 pro 价上限估，报告尾注会如实标注
ARK_PRICE_IN_FLASH=
ARK_PRICE_OUT_FLASH=

# LangSmith 可观测（P5，可选）：填 key 并置 TRACING=true 后，
# 每次运行在 LangSmith 出完整 trace（图节点 + 每次 LLM 调用）
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-radar

# SMTP 发信（P7，周报 PDF 附件）：Gmail 用「应用专用密码」（非登录密码），
# 需先在 Google 账号开两步验证再生成。任一为空则只生成报告不发信。
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=kaishuaisun0322@gmail.com
